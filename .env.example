# Copie este arquivo para ".env" e preencha os valores. O ".env" nunca deve ser commitado.

# Equipe usada para identificar o RESPONSÁVEL de cada audiência no calendário
PAUTACF_EQUIPE=JOSELTON,RAFAEL,NATHALIA,LARISSA

# Fonte do calendário. Use PAUTACF_ICS_URL para um feed .ics público (ex.: a URL
# "iCal" pública de um calendário do Google Agenda) — tem prioridade sobre PAUTACF_ICS,
# que é o caminho de um arquivo .ics local.
PAUTACF_ICS_URL=https://calendar.google.com/calendar/ical/SEU_ID_AQUI/public/basic.ics
PAUTACF_ICS=data/entrada/agenda.ics

# --- Envio de e-mail (opcional, usado com "scripts/gerar_pauta.py --email") ---
SMTP_SERVIDOR=smtp.gmail.com
SMTP_PORTA=587
SMTP_USUARIO=seuemail@gmail.com
SMTP_SENHA=senha-de-app
SMTP_REMETENTE=Pauta CF <seuemail@gmail.com>
PAUTACF_DESTINATARIOS=equipe@calmonefreitas.com.br,outra@calmonefreitas.com.br
